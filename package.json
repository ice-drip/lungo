{
  "name": "@kaffee/lungo",
  "version": "2.0.0",
  "description": "SSH/SFTP deployment CLI tool",
  "main": "dist/bin.js",
  "repository": "ice-drip/lungo",
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublish": "pnpm build"
  },
  "bin": {
    "lungo": "./dist/bin.js"
  },
  "keywords": [
    "cli"
  ],
  "author": "Rikka",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rslib/core": "^0.23.2",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.1.0",
    "@types/ssh2": "^1.15.5",
    "@vitest/coverage-v8": "^4.1.9",
"citty": "^0.2.2",
    "consola": "^3.4.2",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "adm-zip": "0.5.12",
    "console-table-printer": "^2.16.1",
    "dayjs": "^1.11.21",
    "rxjs": "^7.8.2",
    "ssh2": "^1.15.0"
  }
}
